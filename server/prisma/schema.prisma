// server/prisma/schema.prisma

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id        String  @id @default(cuid())
  email     String  @unique
  password  String
  firstName String
  lastName  String
  phone     String?

  // 🏺 Statut Institutionnel
  role       String  @default("USER") // "USER", "PRO", "ADMIN"
  isEmployee Boolean @default(false) // 🏺 Nouveau : Identifie le particulier rattaché à un CE
  memberCode String? @unique

  // 🏺 Attributs Professionnels (CE)
  companyName String?
  siret       String? // 🏺 @unique retiré pour permettre le rattachement de plusieurs salariés

  conceptionLevel Int      @default(0)
  createdAt       DateTime @default(now())

  orders       Order[]
  ownedGroups  CompanyGroup[] // Groupes gérés par ce compte pro (PRO uniquement)
  participants Participant[]

  resetToken        String?
  resetTokenExpires DateTime?
}

model Category {
  id          String    @id @default(uuid())
  name        String    @unique
  description String?
  image       String?
  products    Product[]
}

model Product {
  id          String          @id @default(uuid())
  name        String
  description String?
  image       String?
  categoryId  String
  category    Category        @relation(fields: [categoryId], references: [id])
  volumes     ProductVolume[]
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt
}

model ProductVolume {
  id         String      @id @default(uuid())
  size       Float
  unit       String
  price      Float
  stock      Int         @default(0)
  productId  String
  product    Product     @relation(fields: [productId], references: [id], onDelete: Cascade)
  orderItems OrderItem[]
}

model Workshop {
  id                 String      @id @default(uuid())
  level              Int
  type               String      @default("PARTICULIER") // "PARTICULIER" ou "ENTREPRISE"
  title              String
  description        String
  image              String?
  color              String?
  format             String
  availability       String?
  quote              String
  price              Float // Tarif Public
  priceInstitutional Float       @default(0) // Tarif PRO / Salarié CE
  orderItems         OrderItem[]

  @@unique([level, type])
}

model CompanyGroup {
  id           String @id @default(cuid())
  name         String
  currentLevel Int    @default(0)
  totalSlots   Int    @default(25)

  ownerId String
  owner   User   @relation(fields: [ownerId], references: [id])

  participants Participant[]
  orderItems   OrderItem[]
  createdAt    DateTime      @default(now())
}

model Order {
  id         String      @id @default(cuid())
  reference  String      @unique
  status     String      @default("EN ATTENTE")
  total      Float
  isBusiness Boolean     @default(false)
  userId     String
  user       User        @relation(fields: [userId], references: [id])
  items      OrderItem[]
  createdAt  DateTime    @default(now())
}

model OrderItem {
  id       String  @id @default(cuid())
  name     String?
  quantity Int
  price    Float
  orderId  String
  order    Order   @relation(fields: [orderId], references: [id])

  participants Participant[]

  groupNames String?

  companyGroupId String?
  companyGroup   CompanyGroup? @relation(fields: [companyGroupId], references: [id])

  workshopId String?
  workshop   Workshop?      @relation(fields: [workshopId], references: [id])
  volumeId   String?
  volume     ProductVolume? @relation(fields: [volumeId], references: [id])
}

model Participant {
  id        String  @id @default(cuid())
  firstName String?
  lastName  String?
  phone     String?
  email     String?

  isValidated Boolean   @default(false)
  validatedAt DateTime?

  memberCode String?
  userId     String?
  user       User?   @relation(fields: [userId], references: [id])

  companyGroupId String?
  companyGroup   CompanyGroup? @relation(fields: [companyGroupId], references: [id])

  orderItemId String
  orderItem   OrderItem @relation(fields: [orderItemId], references: [id], onDelete: Cascade)
}

model GiftCard {
  id      String @id @default(cuid())
  code    String @unique // RHUM-XXXX
  amount  Float // Montant initial
  balance Float // Solde restant
  status  String @default("ACTIF") // ACTIF, ÉPUISÉ, EXSPIRÉ

  createdAt DateTime @default(now())
  // 🏺 Date de caducité scellée à 12 mois
  expiresAt DateTime
}
